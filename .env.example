# --- Engine A: OpenAI (optional, used if OPENAI_API_KEY is set) ---
# Fallback to EasyOCR if not set
OPENAI_API_KEY=sk-...

# --- Engine C: HuggingFace Inference API (LLaVA / PaliGemma) ---
# Get free token at https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_...

# Which HuggingFace vision model to use as Engine C
# Options:
#   llava-hf/llava-1.5-7b-hf         (recommended)
#   google/paligemma-3b-mix-448       (lighter)
HF_VISION_MODEL=llava-hf/llava-1.5-7b-hf

# --- Consensus threshold (1.0 = unanimous, 0.67 = majority) ---
# Medical safety requires 1.0
CONSENSUS_THRESHOLD=1.0

# --- Layer 2: NIH DailyMed + OpenFDA (no key required) ---
DAILYMED_BASE_URL=https://dailymed.nlm.nih.gov/dailymed/services/v2
OPENFDA_BASE_URL=https://api.fda.gov/drug
